namespace ElevatorSim
{
    /// <summary>
    /// Events for elevator state changes
    /// </summary>
    public class ElevatorEventArgs : EventArgs
    {
        public int CurrentFloor { get; set; }
        public ElevatorDirection Direction { get; set; }
        public string Message { get; set; }
        public DateTime Timestamp { get; set; }

        public ElevatorEventArgs(int floor, ElevatorDirection direction, string message)
        {
            CurrentFloor = floor;
            Direction = direction;
            Message = message;
            Timestamp = DateTime.Now;
        }
    }

    public enum ElevatorDirection
    {
        Up,
        Down,
        Idle
    }

    /// <summary>
    /// Main elevator controller using intelligent event-driven pattern
    /// </summary>
    public class Elevator
    {
        private int _currentFloor = 1;
        private ElevatorDirection _direction = ElevatorDirection.Idle;
        private HashSet<int> _activeRequests = new HashSet<int>();
        private System.Windows.Forms.Timer _movementTimer;
        private readonly int _totalFloors;

        public event EventHandler<ElevatorEventArgs>? FloorChanged;
        public event EventHandler<ElevatorEventArgs>? DirectionChanged;
        public event EventHandler<ElevatorEventArgs>? RequestAdded;
        public event EventHandler<ElevatorEventArgs>? ElevatorStopped;
        public event EventHandler<ElevatorEventArgs>? DoorsOpened;
        public event EventHandler<ElevatorEventArgs>? DoorsClosed;

        public int CurrentFloor => _currentFloor;
        public ElevatorDirection Direction => _direction;
        public int[] PendingRequests => _activeRequests.OrderBy(x => x).ToArray();

        public Elevator(int totalFloors = 4)
        {
            _totalFloors = totalFloors;
            _movementTimer = new System.Windows.Forms.Timer();
            _movementTimer.Interval = 1500; // 1.5 seconds per floor
            _movementTimer.Tick += MovementTimer_Tick;
        }

        /// <summary>
        /// Request elevator to go to a specific floor with intelligent routing
        /// </summary>
        public void RequestFloor(int floor)
        {
            if (floor < 1 || floor > _totalFloors)
                return;

            if (!_activeRequests.Contains(floor))
            {
                _activeRequests.Add(floor);
                OnRequestAdded(new ElevatorEventArgs(floor, _direction, $"Request added for floor {floor}"));

                // If idle, determine direction based on closest floor
                if (_direction == ElevatorDirection.Idle)
                {
                    ProcessNextRequest();
                }
                else
                {
                    // If moving, check if the new request is closer in the current direction
                    // If so, prioritize it
                    var nextFloor = DetermineNextFloor();
                    if (nextFloor != 0 && Math.Abs(floor - _currentFloor) < Math.Abs(nextFloor - _currentFloor))
                    {
                        // New floor is closer, will be picked up next
                        OnRequestAdded(new ElevatorEventArgs(floor, _direction, $"Floor {floor} will be prioritized (closer)"));
                    }
                }
            }
        }

        /// <summary>
        /// Intelligently determines the next floor to visit
        /// </summary>
        private int DetermineNextFloor()
        {
            if (_activeRequests.Count == 0)
                return 0;

            var sortedRequests = _activeRequests.OrderBy(x => x).ToList();

            if (_direction == ElevatorDirection.Up)
            {
                // Look for floors above current floor in UP direction
                var floorsAbove = sortedRequests.Where(f => f > _currentFloor).ToList();
                if (floorsAbove.Count > 0)
                    return floorsAbove.First(); // Get closest floor above

                // No floors above, reverse direction and go down
                return sortedRequests.Last(); // Go to highest floor first, then reverse
            }
            else if (_direction == ElevatorDirection.Down)
            {
                // Look for floors below current floor in DOWN direction
                var floorsBelow = sortedRequests.Where(f => f < _currentFloor).ToList();
                if (floorsBelow.Count > 0)
                    return floorsBelow.Last(); // Get closest floor below

                // No floors below, reverse direction and go up
                return sortedRequests.First(); // Go to lowest floor first, then reverse
            }
            else // Idle
            {
                // Find closest floor
                int closestFloor = sortedRequests[0];
                int minDistance = Math.Abs(closestFloor - _currentFloor);

                foreach (var floor in sortedRequests)
                {
                    int distance = Math.Abs(floor - _currentFloor);
                    if (distance < minDistance)
                    {
                        minDistance = distance;
                        closestFloor = floor;
                    }
                }

                return closestFloor;
            }
        }

        private void ProcessNextRequest()
        {
            if (_activeRequests.Count == 0)
            {
                if (_direction != ElevatorDirection.Idle)
                {
                    _direction = ElevatorDirection.Idle;
                    OnDirectionChanged(new ElevatorEventArgs(_currentFloor, _direction, "Elevator is now idle"));
                    OnElevatorStopped(new ElevatorEventArgs(_currentFloor, _direction, "No more requests"));
                }
                _movementTimer.Stop();
                return;
            }

            int nextFloor = DetermineNextFloor();

            if (nextFloor == 0)
            {
                ProcessNextRequest();
                return;
            }

            // Determine direction
            if (nextFloor > _currentFloor)
                _direction = ElevatorDirection.Up;
            else if (nextFloor < _currentFloor)
                _direction = ElevatorDirection.Down;
            else
                _direction = ElevatorDirection.Idle;

            if (_direction != ElevatorDirection.Idle)
            {
                OnDirectionChanged(new ElevatorEventArgs(_currentFloor, _direction, $"Moving {_direction}"));
                _movementTimer.Start();
            }
            else
            {
                // Already at the floor
                OpenDoors();
            }
        }

        private void MovementTimer_Tick(object? sender, EventArgs e)
        {
            if (_direction == ElevatorDirection.Up)
            {
                _currentFloor++;
            }
            else if (_direction == ElevatorDirection.Down)
            {
                _currentFloor--;
            }

            OnFloorChanged(new ElevatorEventArgs(_currentFloor, _direction, $"Reached floor {_currentFloor}"));

            // Check if we've reached a requested floor
            if (_activeRequests.Contains(_currentFloor))
            {
                _activeRequests.Remove(_currentFloor);
                OpenDoors();
            }
        }

        private void OpenDoors()
        {
            _movementTimer.Stop();
            OnDoorsOpened(new ElevatorEventArgs(_currentFloor, ElevatorDirection.Idle, $"Doors opened at floor {_currentFloor}"));

            // Schedule door closing after 3 seconds
            var closeTimer = new System.Windows.Forms.Timer();
            closeTimer.Interval = 3000;
            closeTimer.Tick += (s, e) =>
            {
                closeTimer.Stop();
                closeTimer.Dispose();
                OnDoorsClosed(new ElevatorEventArgs(_currentFloor, ElevatorDirection.Idle, $"Doors closed at floor {_currentFloor}"));
                ProcessNextRequest();
            };
            closeTimer.Start();
        }

        // Event raisers
        protected virtual void OnFloorChanged(ElevatorEventArgs e) => FloorChanged?.Invoke(this, e);
        protected virtual void OnDirectionChanged(ElevatorEventArgs e) => DirectionChanged?.Invoke(this, e);
        protected virtual void OnRequestAdded(ElevatorEventArgs e) => RequestAdded?.Invoke(this, e);
        protected virtual void OnElevatorStopped(ElevatorEventArgs e) => ElevatorStopped?.Invoke(this, e);
        protected virtual void OnDoorsOpened(ElevatorEventArgs e) => DoorsOpened?.Invoke(this, e);
        protected virtual void OnDoorsClosed(ElevatorEventArgs e) => DoorsClosed?.Invoke(this, e);
    }
}
