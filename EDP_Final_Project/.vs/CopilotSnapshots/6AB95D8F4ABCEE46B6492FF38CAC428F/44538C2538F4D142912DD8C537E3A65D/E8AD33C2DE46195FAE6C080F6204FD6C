namespace ElevatorSim
{
    public partial class ElevatorForm : Form
    {
        private Elevator _elevator;
        private const int TotalFloors = 3;
        private int _currentFloor = 1;
        private bool _doorsOpen = false;

        public ElevatorForm()
        {
            InitializeComponent();
            _elevator = new Elevator(TotalFloors);
            SubscribeToElevatorEvents();
        }

        private void SubscribeToElevatorEvents()
        {
            _elevator.FloorChanged += Elevator_FloorChanged;
            _elevator.DirectionChanged += Elevator_DirectionChanged;
            _elevator.RequestAdded += Elevator_RequestAdded;
            _elevator.ElevatorStopped += Elevator_ElevatorStopped;
            _elevator.DoorsOpened += Elevator_DoorsOpened;
            _elevator.DoorsClosed += Elevator_DoorsClosed;
        }

        private void Elevator_FloorChanged(object? sender, ElevatorEventArgs e)
        {
            this.Invoke(() =>
            {
                _currentFloor = e.CurrentFloor;
                var display = GetCurrentFloorDisplay();
                if (display != null)
                {
                    display.Text = e.CurrentFloor.ToString();
                }
                var viz = GetElevatorVisualization();
                if (viz != null) viz.Invalidate();
                LogEvent($"⬆️ Reached Floor {e.CurrentFloor}");
            });
        }

        private void Elevator_DirectionChanged(object? sender, ElevatorEventArgs e)
        {
            this.Invoke(() =>
            {
                LogEvent($"🔄 Direction: {e.Direction}");
            });
        }

        private void Elevator_RequestAdded(object? sender, ElevatorEventArgs e)
        {
            this.Invoke(() =>
            {
                LogEvent($"📍 Request Added: Floor {e.CurrentFloor}");
                HighlightFloorButton(e.CurrentFloor, true);
            });
        }

        private void Elevator_ElevatorStopped(object? sender, ElevatorEventArgs e)
        {
            this.Invoke(() =>
            {
                LogEvent($"🛑 Elevator Stopped at Floor {e.CurrentFloor}");
            });
        }

        private void Elevator_DoorsOpened(object? sender, ElevatorEventArgs e)
        {
            this.Invoke(() =>
            {
                _doorsOpen = true;
                var viz = GetElevatorVisualization();
                if (viz != null) viz.Invalidate();
                LogEvent($"🚪 Doors Opened at Floor {e.CurrentFloor}");
            });
        }

        private void Elevator_DoorsClosed(object? sender, ElevatorEventArgs e)
        {
            this.Invoke(() =>
            {
                _doorsOpen = false;
                HighlightFloorButton(e.CurrentFloor, false);
                var viz = GetElevatorVisualization();
                if (viz != null) viz.Invalidate();
                LogEvent($"🚪 Doors Closed - Continuing...");
            });
        }

        private void HighlightFloorButton(int floor, bool highlight)
        {
            var buttons = GetFloorButtons();
            if (buttons != null && floor >= 1 && floor <= buttons.Length)
            {
                var btn = buttons[floor - 1];
                if (highlight)
                {
                    btn.BackColor = System.Drawing.Color.Yellow;
                    btn.ForeColor = System.Drawing.Color.Black;
                }
                else
                {
                    btn.BackColor = System.Drawing.Color.White;
                    btn.ForeColor = System.Drawing.Color.Black;
                }
            }
        }

        private void LogEvent(string message)
        {
            var eventLog = GetEventLogDisplay();
            if (eventLog != null)
            {
                string timestamp = DateTime.Now.ToString("HH:mm:ss");
                eventLog.Items.Insert(0, $"[{timestamp}] {message}");

                // Keep only last 100 events
                while (eventLog.Items.Count > 100)
                {
                    eventLog.Items.RemoveAt(eventLog.Items.Count - 1);
                }
            }
        }

        protected override void OnLoad(EventArgs e)
        {
            base.OnLoad(e);

            // Hook up button clicks
            var buttons = GetFloorButtons();
            if (buttons != null)
            {
                foreach (var btn in buttons)
                {
                    btn.Click += (s, e) =>
                    {
                        if (s is Button button && button.Tag is int floor)
                        {
                            _elevator.RequestFloor(floor);
                        }
                    };
                }
            }

            // Hook up paint events
            var viz = GetElevatorVisualization();
            if (viz != null)
            {
                viz.Paint += (s, e) => DrawElevatorVisualization(e.Graphics);
            }

            LogEvent("✅ Elevator System Started");
            LogEvent("Select a floor to call the elevator");
        }

        private void DrawElevatorVisualization(Graphics g)
        {
            var viz = GetElevatorVisualization();
            if (viz == null) return;

            int width = viz.Width;
            int height = viz.Height;
            int elevatorWidth = 140;
            int elevatorHeight = 180;

            // Calculate spacing for 3 floors
            int floorSpacing = height / 3;
            int elevatorX = (width - elevatorWidth) / 2;

            // Draw 3 elevator cars stacked vertically (representing floors 3, 2, 1 from top to bottom)
            for (int floor = 3; floor >= 1; floor--)
            {
                int yPos = (3 - floor) * floorSpacing + 40;
                bool isCurrentFloor = (_currentFloor == floor);

                // Draw elevator shaft background
                using (Brush shaftBrush = new SolidBrush(System.Drawing.Color.FromArgb(100, 100, 100)))
                {
                    g.FillRectangle(shaftBrush, elevatorX - 20, yPos - 20, elevatorWidth + 40, elevatorHeight);
                }

                // Draw elevator car border
                using (Pen borderPen = new Pen(System.Drawing.Color.DarkGray, 3))
                {
                    g.DrawRectangle(borderPen, elevatorX, yPos, elevatorWidth, elevatorHeight);
                }

                if (isCurrentFloor && _doorsOpen)
                {
                    // Draw OPEN doors (gap in middle)
                    using (Brush doorBrush = new SolidBrush(System.Drawing.Color.Silver))
                    {
                        // Left door
                        g.FillRectangle(doorBrush, elevatorX + 3, yPos + 20, 60, elevatorHeight - 40);
                        // Right door
                        g.FillRectangle(doorBrush, elevatorX + 80, yPos + 20, 57, elevatorHeight - 40);
                    }
                    // Draw door separator gap
                    using (Pen gapPen = new Pen(System.Drawing.Color.Black, 2))
                    {
                        g.DrawLine(gapPen, elevatorX + 70, yPos + 20, elevatorX + 70, yPos + elevatorHeight - 20);
                    }
                }
                else
                {
                    // Draw CLOSED doors
                    using (Brush doorBrush = new SolidBrush(System.Drawing.Color.Silver))
                    {
                        g.FillRectangle(doorBrush, elevatorX + 3, yPos + 20, elevatorWidth - 6, elevatorHeight - 40);
                    }
                    using (Pen doorPen = new Pen(System.Drawing.Color.Black, 2))
                    {
                        g.DrawRectangle(doorPen, elevatorX + 3, yPos + 20, elevatorWidth - 6, elevatorHeight - 40);
                        // Middle door line
                        g.DrawLine(doorPen, elevatorX + elevatorWidth / 2, yPos + 20, elevatorX + elevatorWidth / 2, yPos + elevatorHeight - 20);
                    }
                }

                // Draw floor label
                string floorLabel = floor == 1 ? "GF (1)" : floor.ToString();
                using (Font font = new Font("Arial", 10, FontStyle.Bold))
                using (Brush brush = new SolidBrush(isCurrentFloor ? System.Drawing.Color.Red : System.Drawing.Color.Black))
                {
                    g.DrawString(floorLabel, font, brush, elevatorX - 40, yPos + elevatorHeight + 10);
                }

                // Highlight current floor
                if (isCurrentFloor)
                {
                    using (Pen highlightPen = new Pen(System.Drawing.Color.Red, 3))
                    {
                        g.DrawRectangle(highlightPen, elevatorX - 25, yPos - 25, elevatorWidth + 50, elevatorHeight + 50);
                    }
                }
            }
        }

        protected override void OnClosed(EventArgs e)
        {
            base.OnClosed(e);
        }
    }
}
