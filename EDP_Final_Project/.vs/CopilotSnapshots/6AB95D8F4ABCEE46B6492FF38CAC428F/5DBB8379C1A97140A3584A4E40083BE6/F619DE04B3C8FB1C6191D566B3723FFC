namespace ElevatorSim
{
    public partial class ElevatorForm : Form
    {
        private Elevator _elevator;
        private const int TotalFloors = 3;
        private int _currentFloor = 1;
        private bool _doorsOpen = false;

        public ElevatorForm()
        {
            InitializeComponent();
            _elevator = new Elevator(TotalFloors);
            SubscribeToElevatorEvents();
        }

        private void SubscribeToElevatorEvents()
        {
            _elevator.FloorChanged += Elevator_FloorChanged;
            _elevator.DirectionChanged += Elevator_DirectionChanged;
            _elevator.RequestAdded += Elevator_RequestAdded;
            _elevator.ElevatorStopped += Elevator_ElevatorStopped;
            _elevator.DoorsOpened += Elevator_DoorsOpened;
            _elevator.DoorsClosed += Elevator_DoorsClosed;
        }

        private void Elevator_FloorChanged(object? sender, ElevatorEventArgs e)
        {
            this.Invoke(() =>
            {
                _currentFloor = e.CurrentFloor;
                var display = GetCurrentFloorDisplay();
                if (display != null)
                {
                    display.Text = e.CurrentFloor.ToString();
                }
                var viz = GetElevatorVisualization();
                if (viz != null) viz.Invalidate();
                LogEvent($"⬆️ Reached Floor {e.CurrentFloor}");
            });
        }

        private void Elevator_DirectionChanged(object? sender, ElevatorEventArgs e)
        {
            this.Invoke(() =>
            {
                LogEvent($"🔄 Direction: {e.Direction}");
            });
        }

        private void Elevator_RequestAdded(object? sender, ElevatorEventArgs e)
        {
            this.Invoke(() =>
            {
                LogEvent($"📍 Request Added: Floor {e.CurrentFloor}");
                HighlightFloorButton(e.CurrentFloor, true);
            });
        }

        private void Elevator_ElevatorStopped(object? sender, ElevatorEventArgs e)
        {
            this.Invoke(() =>
            {
                LogEvent($"🛑 Elevator Stopped at Floor {e.CurrentFloor}");
            });
        }

        private void Elevator_DoorsOpened(object? sender, ElevatorEventArgs e)
        {
            this.Invoke(() =>
            {
                _doorsOpen = true;
                var viz = GetElevatorVisualization();
                if (viz != null) viz.Invalidate();
                LogEvent($"🚪 Doors Opened at Floor {e.CurrentFloor}");
            });
        }

        private void Elevator_DoorsClosed(object? sender, ElevatorEventArgs e)
        {
            this.Invoke(() =>
            {
                _doorsOpen = false;
                HighlightFloorButton(e.CurrentFloor, false);
                var viz = GetElevatorVisualization();
                if (viz != null) viz.Invalidate();
                LogEvent($"🚪 Doors Closed - Continuing...");
            });
        }

        private void HighlightFloorButton(int floor, bool highlight)
        {
            var buttons = GetFloorButtons();
            if (buttons != null && floor >= 1 && floor <= buttons.Length)
            {
                var btn = buttons[floor - 1];
                if (highlight)
                {
                    btn.BackColor = System.Drawing.Color.Yellow;
                    btn.ForeColor = System.Drawing.Color.Black;
                }
                else
                {
                    btn.BackColor = System.Drawing.Color.White;
                    btn.ForeColor = System.Drawing.Color.Black;
                }
            }
        }

        private void LogEvent(string message)
        {
            var eventLog = GetEventLogDisplay();
            if (eventLog != null)
            {
                string timestamp = DateTime.Now.ToString("HH:mm:ss");
                eventLog.Items.Insert(0, $"[{timestamp}] {message}");

                // Keep only last 100 events
                while (eventLog.Items.Count > 100)
                {
                    eventLog.Items.RemoveAt(eventLog.Items.Count - 1);
                }
            }
        }

        protected override void OnLoad(EventArgs e)
        {
            base.OnLoad(e);

            // Hook up button clicks
            var buttons = GetFloorButtons();
            if (buttons != null)
            {
                foreach (var btn in buttons)
                {
                    btn.Click += (s, e) =>
                    {
                        if (s is Button button && button.Tag is int floor)
                        {
                            _elevator.RequestFloor(floor);
                        }
                    };
                }
            }

            // Hook up paint events
            var viz = GetElevatorVisualization();
            if (viz != null)
            {
                viz.Paint += (s, e) => DrawElevatorVisualization(e.Graphics);
            }

            LogEvent("✅ Elevator System Started");
            LogEvent("Select a floor to call the elevator");
        }

        private void DrawElevatorVisualization(Graphics g)
        {
            var viz = GetElevatorVisualization();
            if (viz == null) return;

            int width = viz.Width;
            int height = viz.Height;
            int elevatorWidth = 140;
            int elevatorHeight = 160;
            int padding = 20;

            // Calculate spacing for 3 floors (CORRECTLY: 1 at bottom, 3 at top)
            int floorSpacing = (height - 60) / 3;
            int elevatorX = (width - elevatorWidth) / 2;

            // Draw 3 floor sections VERTICALLY: Floor 3 (top), Floor 2 (middle), Floor 1 (bottom)
            for (int floor = 1; floor <= 3; floor++)
            {
                // Floor 1 is at bottom, Floor 3 is at top
                // yPos = height - (floor * floorSpacing) - padding
                int yPos = height - (floor * floorSpacing) - padding;
                bool isCurrentFloor = (_currentFloor == floor);

                // Draw floor background
                using (Brush floorBgBrush = new SolidBrush(System.Drawing.Color.FromArgb(200, 200, 200)))
                {
                    g.FillRectangle(floorBgBrush, 10, yPos - floorSpacing + 20, width - 20, floorSpacing - 10);
                }

                // Draw floor separator line
                using (Pen linePen = new Pen(System.Drawing.Color.Black, 2))
                {
                    g.DrawLine(linePen, 10, yPos, width - 10, yPos);
                }

                // Draw elevator car (only at current floor position)
                if (isCurrentFloor)
                {
                    // Draw elevator shaft background
                    using (Brush shaftBrush = new SolidBrush(System.Drawing.Color.FromArgb(100, 100, 100)))
                    {
                        g.FillRectangle(shaftBrush, elevatorX - 20, yPos - elevatorHeight - 5, elevatorWidth + 40, elevatorHeight);
                    }

                    // Draw elevator car border
                    using (Pen borderPen = new Pen(System.Drawing.Color.DarkGray, 4))
                    {
                        g.DrawRectangle(borderPen, elevatorX, yPos - elevatorHeight - 5, elevatorWidth, elevatorHeight);
                    }

                    // Draw elevator car fill
                    using (Brush carBrush = new SolidBrush(System.Drawing.Color.FromArgb(200, 200, 220)))
                    {
                        g.FillRectangle(carBrush, elevatorX + 2, yPos - elevatorHeight - 3, elevatorWidth - 4, elevatorHeight - 4);
                    }

                    if (_doorsOpen)
                    {
                        // Draw OPEN doors (gap in middle)
                        using (Brush doorBrush = new SolidBrush(System.Drawing.Color.FromArgb(220, 220, 220)))
                        {
                            // Left door
                            int doorLeft = elevatorX + 5;
                            int doorTop = yPos - elevatorHeight + 10;
                            int doorGap = elevatorWidth / 2 - 5;
                            g.FillRectangle(doorBrush, doorLeft, doorTop, doorGap, elevatorHeight - 20);

                            // Right door
                            int doorRight = elevatorX + elevatorWidth / 2 + 5;
                            g.FillRectangle(doorBrush, doorRight, doorTop, doorGap, elevatorHeight - 20);
                        }

                        // Draw door handles
                        using (Pen handlePen = new Pen(System.Drawing.Color.DarkGray, 3))
                        {
                            int handleY = yPos - elevatorHeight / 2 - 5;
                            // Left door handle
                            g.DrawLine(handlePen, elevatorX + elevatorWidth / 4, handleY, elevatorX + elevatorWidth / 4, handleY + 60);
                            // Right door handle
                            g.DrawLine(handlePen, elevatorX + 3 * elevatorWidth / 4, handleY, elevatorX + 3 * elevatorWidth / 4, handleY + 60);
                        }
                    }
                    else
                    {
                        // Draw CLOSED doors
                        using (Brush doorBrush = new SolidBrush(System.Drawing.Color.FromArgb(200, 200, 200)))
                        {
                            g.FillRectangle(doorBrush, elevatorX + 3, yPos - elevatorHeight + 10, elevatorWidth - 6, elevatorHeight - 20);
                        }

                        using (Pen doorPen = new Pen(System.Drawing.Color.Black, 2))
                        {
                            g.DrawRectangle(doorPen, elevatorX + 3, yPos - elevatorHeight + 10, elevatorWidth - 6, elevatorHeight - 20);
                            // Middle door line
                            g.DrawLine(doorPen, elevatorX + elevatorWidth / 2, yPos - elevatorHeight + 10, elevatorX + elevatorWidth / 2, yPos - 10);
                        }

                        // Draw door handles when closed
                        using (Pen handlePen = new Pen(System.Drawing.Color.DarkGray, 3))
                        {
                            int handleY = yPos - elevatorHeight / 2 - 5;
                            // Left door handle
                            g.DrawLine(handlePen, elevatorX + elevatorWidth / 4, handleY, elevatorX + elevatorWidth / 4, handleY + 60);
                            // Right door handle
                            g.DrawLine(handlePen, elevatorX + 3 * elevatorWidth / 4, handleY, elevatorX + 3 * elevatorWidth / 4, handleY + 60);
                        }
                    }

                    // Draw current floor indicator inside elevator
                    using (Font font = new Font("Arial", 28, FontStyle.Bold))
                    using (Brush brush = new SolidBrush(System.Drawing.Color.DarkBlue))
                    {
                        string floorText = floor == 1 ? "1" : floor.ToString();
                        SizeF textSize = g.MeasureString(floorText, font);
                        float textX = elevatorX + (elevatorWidth - textSize.Width) / 2;
                        float textY = yPos - elevatorHeight + 15;
                        g.DrawString(floorText, font, brush, textX, textY);
                    }
                }

                // Draw floor label on the left
                string floorLabel = floor == 1 ? "1" : floor == 2 ? "2" : "3";
                using (Font font = new Font("Arial", 12, FontStyle.Bold))
                using (Brush brush = new SolidBrush(isCurrentFloor ? System.Drawing.Color.Red : System.Drawing.Color.Black))
                {
                    g.DrawString(floorLabel, font, brush, 5, yPos - 20);
                }
            }

            // Draw elevator shaft outline
            using (Pen shaftPen = new Pen(System.Drawing.Color.Black, 3))
            {
                g.DrawRectangle(shaftPen, elevatorX - 30, 10, elevatorWidth + 60, height - 40);
            }
        }

        protected override void OnClosed(EventArgs e)
        {
            base.OnClosed(e);
        }
    }
}
